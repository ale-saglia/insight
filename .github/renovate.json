{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchManagers": ["bundler", "npm"],
      "groupName": "ruby/js deps",
      "schedule": ["every 2 weeks on monday"]
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "docker base images",
      "schedule": ["monthly"]
    }
  ],
  "docker": {
    "pinDigests": false
  }
}
