{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pelican: Build",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "make",
      "runtimeArgs": ["build"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "console"
    },
    {
      "name": "Pelican: Preview",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "make",
      "runtimeArgs": ["preview"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "console"
    },
    {
      "name": "Pelican: Clean & Build",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "make",
      "runtimeArgs": ["rebuild"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "console"
    }
  ]
}
