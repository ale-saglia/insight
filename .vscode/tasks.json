{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pelican: Setup (install deps)",
      "type": "shell",
      "command": "python3 -m venv .venv && .venv/bin/pip install -q -r requirements.txt && echo 'Setup complete.'",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Pelican: Build",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/build-local.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Pelican: Preview (localhost:4000)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/preview-local.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Pelican: Clean & Build",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "rm -rf _site && bash scripts/build-local.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Git: Update Modified Dates",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/update-modified-dates.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
