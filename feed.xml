---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self"/>
  <link href="{{ '/' | absolute_url }}"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
    <uri>{{ site.author.url | xml_escape }}</uri>
  </author>
  <generator uri="https://jekyllrb.com/" version="4.2.2">Jekyll</generator>
  <subtitle>{{ site.description | xml_escape }}</subtitle>

  {% assign posts = site.pages | where_exp: "item", "item.path contains 'src/'" | sort: "created" | reverse %}
  {% for post in posts %}
    {% if post.title and post.excerpt %}
    <entry>
      <title type="html">{{ post.title | xml_escape }}</title>
      <link href="{{ site.url }}{{ post.url }}"/>
      <id>{{ site.url }}{{ post.url }}</id>
      <published>{{ post.created | date_to_xmlschema }}</published>
      <updated>{% if post.modified %}{{ post.modified | date_to_xmlschema }}{% else %}{{ post.created | date_to_xmlschema }}{% endif %}</updated>
      <author>
        <name>{{ site.author.name | xml_escape }}</name>
        <uri>{{ site.author.url | xml_escape }}</uri>
      </author>
      {% if post.category %}
        <category term="{{ post.category }}"/>
      {% endif %}
      <content type="html">{{ post.content | markdownify | xml_escape }}</content>
      <summary type="html">{{ post.excerpt | xml_escape }}</summary>
    </entry>
    {% endif %}
  {% endfor %}
</feed>
